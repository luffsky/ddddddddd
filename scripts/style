local Players = game:GetService("Players")
local RS = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local plr = Players.LocalPlayer
local remotes = ReplicatedStorage:WaitForChild("Remotes")
 
local Rejoin = remotes:WaitForChild("Rejoin") -- Assume common remote names, adjust if needed
local RechargeBlades = remotes:WaitForChild("RechargeBlades")
local char = plr.Character or plr.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")
 
-- Vars
local autoFarm = false
local autoRelaunch = false
local autoRecharge = false
local autoExit = false
local connections = {}
 
local function clearConns()
  for _,conn in pairs(connections) do
    conn:Disconnect()
  end
  connections = {}
end
 
local function updateChar(newChar)
  char = newChar
  hrp = char:WaitForChild("HumanoidRootPart")
  hum = char:WaitForChild("Humanoid")
end
 
plr.CharacterAdded:Connect(updateChar)
 
-- Fly helper for tp (simple)
local flying = false
local flySpeed = 50
local function toggleFly(on)
  flying = on
  if on then
    local bg = Instance.new("BodyVelocity",hrp)
    bg.MaxForce = Vector3.new(4000,4000,4000)
    bg.Velocity = Vector3.new(0,0.1,0)
    table.insert(connections,RS.Heartbeat:Connect(function()
      if flying and hrp then
        local cam = workspace.CurrentCamera
        local vel = (cam.CFrame.LookVector * (keys.w.Value and flySpeed or 0)) + (cam.CFrame.RightVector * (keys.a.Value and -flySpeed or keys.d.Value and flySpeed or 0)) + Vector3.new(0,(keys.s.Value and -flySpeed or keys.space.Value and flySpeed or 0),0)
        bg.Velocity = vel
      end
    end))
  end
end
 
