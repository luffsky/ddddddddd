local function createToggle(name)
  local togFrame = Instance.new("Frame",scroll)
  togFrame.Size = UDim2.new(1,0,0,40)
  togFrame.BackgroundColor3 = Color3.fromRGB(40,40,40)
  local togCorner = Instance.new("UICorner",togFrame)
  togCorner.CornerRadius = UDim.new(0,8)
  local togLabel = Instance.new("TextLabel",togFrame)
  togLabel.Size = UDim2.new(0.7,0,1,0)
  togLabel.BackgroundTransparency = 1
  togLabel.Text = name .. ": OFF"
  togLabel.TextColor3 = Color3.new(0.8,0.8,0.8)
  togLabel.Font = Enum.Font.Gotham
  togLabel.TextSize = 16
  togLabel.TextXAlignment = Enum.TextXAlignment.Left
  local togBtn = Instance.new("TextButton",togFrame)
  togBtn.Size = UDim2.new(0.25,0,0.6,0)
  togBtn.Position = UDim2.new(0.72,0,0.2,0)
  togBtn.BackgroundColor3 = Color3.fromRGB(100,0,0)
  togBtn.Text = ""
  local togBtnCorner = Instance.new("UICorner",togBtn)
  togBtnCorner.CornerRadius = UDim.new(0,6)
  togBtn.MouseButton1Click:Connect(function()
    -- Toggle logic here per name
    local state = togLabel.Text:find("ON")
    if state then
      togLabel.Text = name .. ": OFF"
      togLabel.TextColor3 = Color3.new(0.8,0.8,0.8)
      togBtn.BackgroundColor3 = Color3.fromRGB(100,0,0)
      -- Off logic
